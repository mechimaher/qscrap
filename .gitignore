```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Environment variables
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temp files
*.tmp

# Coverage reports
coverage/
htmlcov/
*.coverage

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Package manager caches
.npm/
.yarn/
.pnpm-store/

# OS generated files
.DS_Store
Thumbs.db

# Mobile app specific
*.apk
*.ipa
*.aab
android/build/
ios/build/
ios/Pods/
```